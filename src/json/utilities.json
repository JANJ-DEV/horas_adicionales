  "utility_definitions": {
    "comment_box": {
      "type": "textarea",
      "label": "Comentario / Justificación",
      "required": false
    },
    "motivo_extension_comercial": {
      "type": "select",
      "label": "Motivo de la extensión",
      "required": true,
      "options": ["Cierre de caja", "Atención a cliente rezagado", "Inventario", "Otro"]
    },
    "cliente_visitado": {
      "type": "text",
      "label": "Cliente o Empresa visitada",
      "required": true
    },
    "km_recorridos": {
      "type": "number",
      "label": "Kilómetros recorridos",
      "required": false
    },
    "num_caja": {
      "type": "text",
      "label": "Número de caja",
      "required": true
    },
    "incidencia_cuadre": {
      "type": "textarea",
      "label": "Incidencia en el cuadre",
      "required": false
    },
    "num_ticket_atencion": {
      "type": "text",
      "label": "Nº de ticket o reclamación",
      "required": true
    },
    "num_albaran": {
      "type": "text",
      "label": "Número de albarán o pedido",
      "required": true
    },
    "ruta_origen_destino": {
      "type": "text",
      "label": "Ruta (Origen - Destino)",
      "required": true
    },
    "matricula": {
      "type": "text",
      "label": "Matrícula del vehículo",
      "required": true
    },
    "motivo_retraso_transporte": {
      "type": "select",
      "label": "Motivo del retraso",
      "required": true,
      "options": ["Tráfico", "Avería", "Retraso del cliente", "Otro"]
    },
    "muelle_carga": {
      "type": "text",
      "label": "Muelle de carga/descarga",
      "required": false
    },
    "id_proyecto": {
      "type": "text",
      "label": "ID del Proyecto o Cliente",
      "required": true
    },
    "ticket_jira": {
      "type": "text",
      "label": "Nº de Ticket (ej. Jira / Trello)",
      "required": true
    },
    "tipo_intervencion_it": {
      "type": "select",
      "label": "Tipo de intervención",
      "required": true,
      "options": [
        "Despliegue a producción",
        "Caída de servidor",
        "Mantenimiento programado",
        "Incidencia de seguridad"
      ]
    },
    "tipo_urgencia": {
      "type": "text",
      "label": "Tipo de urgencia o emergencia",
      "required": true
    },
    "num_historial_paciente": {
      "type": "text",
      "label": "Nº Historial del paciente (Anonimizado)",
      "required": true
    },
    "nombre_residente": {
      "type": "text",
      "label": "Nombre del residente/usuario atendido",
      "required": false
    },
    "orden_fabricacion": {
      "type": "text",
      "label": "Orden de Fabricación (OF)",
      "required": true
    },
    "linea_produccion": {
      "type": "text",
      "label": "Línea de producción o máquina",
      "required": true
    },
    "motivo_parada_maquina": {
      "type": "textarea",
      "label": "Motivo de parada o reparación",
      "required": true
    },
    "codigo_obra": {
      "type": "text",
      "label": "Código o Nombre de la obra",
      "required": true
    },
    "fase_proyecto": {
      "type": "select",
      "label": "Fase del proyecto",
      "required": true,
      "options": ["Cimentación", "Estructura", "Acabados", "Entrega"]
    },
    "zona_trabajo": {
      "type": "text",
      "label": "Zona de trabajo",
      "required": true
    },
    "motivo_retraso_obra": {
      "type": "select",
      "label": "Motivo de horas extra",
      "required": false,
      "options": ["Retraso de material", "Climatología adversa", "Fallo técnico", "Otro"]
    },
    "turno_cubierto": {
      "type": "text",
      "label": "Turno o compañero cubierto",
      "required": false
    },
    "nombre_evento": {
      "type": "text",
      "label": "Nombre del Evento o Banquete",
      "required": false
    },
    "incidencia_huespedes": {
      "type": "textarea",
      "label": "Incidencia (Overbooking, Check-in nocturno)",
      "required": true
    },
    "nombre_grupo_turistico": {
      "type": "text",
      "label": "Nombre o ID del grupo",
      "required": true
    },
    "ruta_turistica": {
      "type": "text",
      "label": "Ruta realizada",
      "required": true
    },
    "zona_explotacion": {
      "type": "text",
      "label": "Finca, Parcela o Zona",
      "required": true
    },
    "kilos_recolectados": {
      "type": "number",
      "label": "Kilos/Litros procesados",
      "required": false
    },
    "condicion_climatica": {
      "type": "text",
      "label": "Condición climática",
      "required": false
    },
    "aviso_incidencia_forestal": {
      "type": "text",
      "label": "Nº Aviso o Incidencia",
      "required": true
    },
    "tipo_tarea_docente": {
      "type": "select",
      "label": "Tipo de tarea",
      "required": true,
      "options": ["Corrección de exámenes", "Tutoría", "Claustro", "Preparación de clases"]
    },
    "grupo_clase_afectada": {
      "type": "text",
      "label": "Grupo o Clase afectada",
      "required": true
    },
    "departamento_afectado": {
      "type": "text",
      "label": "Departamento",
      "refquired": false
    },
    "cierre_contable": {
      "type": "select",
      "label": "Tipo de gestión",
      "required": true,
      "options": ["Cierre Mensual", "Cierre Trimestral", "Auditoría", "Otro"]
    },
    "num_expediente_legal": {
      "type": "text",
      "label": "Número de Expediente o Caso",
      "required": true
    },
    "nombre_produccion": {
      "type": "text",
      "label": "Nombre de la producción / Proyecto",
      "dbKey": "production_name",
      "required": true
    },
    "tipo_actividad_artistica": {
      "type": "select",
      "label": "Tipo de actividad",
      "required": true,
      "options": ["Ensayo", "Rodaje exterior", "Actuación en vivo", "Montaje"]
    }
  }
}
